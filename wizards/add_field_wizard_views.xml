<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_cs_followup_add_field_wizard_form" model="ir.ui.view">
        <field name="name">cs.followup.add.field.wizard.form</field>
        <field name="model">cs.followup.add.field.wizard</field>
        <field name="arch" type="xml">
            <form string="Nuevo campo">
                <group>
                    <group>
                        <field name="template_id"/>
                        <field name="section_id"/>
                        <field name="sequence" string="Orden"/>
                        <field name="name"/>
                        <field name="field_type"/>
                        <field name="required"/>
                        <field name="code"/>
                    </group>
                    <group>
                        <field name="help_text" placeholder="Texto de ayuda para el usuario (opcional)"/>
                        <field name="option_values" invisible="field_type != 'selection'" placeholder="Una opción por línea"/>
                        <field name="min_value" invisible="field_type != 'scale_1_10'" placeholder="Ej: 1"/>
                        <field name="max_value" invisible="field_type != 'scale_1_10'" placeholder="Ej: 10"/>
                    </group>
                </group>
                <footer>
                    <button name="action_create_field" type="object" string="Crear campo" class="btn-primary"/>
                    <button string="Cancelar" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
