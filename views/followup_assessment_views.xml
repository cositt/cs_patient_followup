<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_cs_followup_assessment_list" model="ir.ui.view">
        <field name="name">cs.followup.assessment.list</field>
        <field name="model">cs.followup.assessment</field>
        <field name="arch" type="xml">
            <list>
                <field name="assessment_date"/>
                <field name="patient_id"/>
                <field name="template_id"/>
                <field name="clinician_id"/>
                <field name="state"/>
                <field name="company_id"/>
            </list>
        </field>
    </record>

    <record id="view_cs_followup_assessment_form" model="ir.ui.view">
        <field name="name">cs.followup.assessment.form</field>
        <field name="model">cs.followup.assessment</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_open_guided_wizard" type="object" string="Rellenado guiado" class="btn-secondary" invisible="state != 'draft'"/>
                    <button name="action_mark_done" type="object" string="Completar" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_set_draft" type="object" string="Borrador" invisible="state == 'draft'"/>
                    <button name="action_cancel" type="object" string="Cancelar" invisible="state == 'cancelled'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,done,cancelled"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="patient_id"/>
                            <field name="template_id"/>
                            <field name="template_version" readonly="1"/>
                        </group>
                        <group>
                            <field name="assessment_date"/>
                            <field name="clinician_id"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Respuestas">
                            <field name="answer_ids">
                                <list editable="bottom">
                                    <field name="template_field_id" domain="[('template_id', '=', parent.template_id)]"/>
                                    <field name="answer_type" readonly="1"/>
                                    <field name="value_number" optional="show"/>
                                    <field name="value_boolean" optional="show"/>
                                    <field name="value_text" optional="show"/>
                                    <field name="value_text_long" optional="hide"/>
                                    <field name="value_date" optional="show"/>
                                    <field name="value_selection" optional="show"/>
                                </list>
                            </field>
                        </page>
                        <page string="Observaciones">
                            <field name="notes"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_cs_followup_assessment" model="ir.actions.act_window">
        <field name="name">Evaluaciones</field>
        <field name="res_model">cs.followup.assessment</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
