<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="group_followup_admin" model="res.groups">
        <field name="name">Followup Admin</field>
        <field name="user_ids" eval="[(4, ref('base.user_admin'))]"/>
    </record>

    <record id="group_followup_clinician" model="res.groups">
        <field name="name">Followup Clinician</field>
    </record>

    <record id="group_followup_readonly" model="res.groups">
        <field name="name">Followup Readonly</field>
    </record>

    <record id="rule_followup_template_company" model="ir.rule">
        <field name="name">Followup Template by Company</field>
        <field name="model_id" ref="model_cs_followup_template"/>
        <field name="domain_force">[('company_id', 'in', user.company_ids.ids)]</field>
        <field name="groups" eval="[(4, ref('group_followup_admin')), (4, ref('group_followup_clinician')), (4, ref('group_followup_readonly'))]"/>
    </record>

    <record id="rule_followup_assessment_company" model="ir.rule">
        <field name="name">Followup Assessment by Company</field>
        <field name="model_id" ref="model_cs_followup_assessment"/>
        <field name="domain_force">[('company_id', 'in', user.company_ids.ids)]</field>
        <field name="groups" eval="[(4, ref('group_followup_admin')), (4, ref('group_followup_clinician')), (4, ref('group_followup_readonly'))]"/>
    </record>
</odoo>
